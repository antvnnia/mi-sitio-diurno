body{

background:#f5f5f5;

font-family:Arial, Helvetica, sans-serif;

}

.card{

transition:0.3s;

margin-bottom:20px;

}

.card:hover{

transform:scale(1.05);

box-shadow:0px 5px 15px rgba(0,0,0,.3);

}

.card img{

height:220px;

object-fit:cover;

}

h2{

font-weight:bold;

}

footer{

margin-top:40px;

}
.card{

transition:0.3s;

}

.card:hover{

transform:scale(1.05);

box-shadow:0 5px 15px rgba(0,0,0,.3);

}
.card img{
    height:220px;
    object-fit:cover;
}

footer{
    width:100%;
}